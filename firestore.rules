rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users top-level doc — readable by anyone, writable by owner
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Tracked subcollection — only the owner can read/write their own tracked lists
      match /tracked/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Friends subcollection
      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }

      // Friend requests
      match /friend_requests/{fromUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == fromUid);
      }

      // Presence
      match /presence/{presenceDoc} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Catalysts
    match /catalysts/{catId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Votes
    match /votes/{voteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // NB-MD09: creator-level fire/poop votes
    match /creator_votes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.voterId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.voterId;
      allow delete: if request.auth != null
        && resource.data.voterId == request.auth.uid;
    }

    // NodeSplit
    match /nodesplit_questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid;
      allow delete: if false;
    }
    match /nodesplit_option_counts/{questionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /nodesplit_votes/{voteId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }
    match /nodesplit_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text.size() <= 280;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }
  }
}
