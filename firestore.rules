rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      match /data/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /prefs/{prefId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /deleted_sessions/{backupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /account_backups/{backupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /fileRegistry/{fileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == friendId);
      }
      match /friend_requests/{requestId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == requestId);
        allow create: if request.auth != null
          && request.auth.uid == requestId
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.keys().hasAll(['fromUid', 'fromUsername', 'fromHex', 'status', 'createdAt'])
          && request.resource.data.status == 'pending';
      }
      match /session_invites/{inviteId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create, write: if request.auth != null;
      }
      match /presence/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      match /tracked/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /worlds/{worldId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /worlds/{worldId}/presence/{userId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /suggestions/{suggestionId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['text', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow read, update, delete: if false;
    }
    match /userLookup/{key} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /shared_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == memberId
              || get(/databases/$(database)/documents/shared_sessions/$(sessionId)).data.ownerUid == request.auth.uid);
        allow delete: if request.auth != null
          && (request.auth.uid == memberId
              || get(/databases/$(database)/documents/shared_sessions/$(sessionId)).data.ownerUid == request.auth.uid);
      }
    }
    match /dms/{convoId} {
      // convoId format: dm_{uid1}_{uid2} (sorted) or self_{uid}.
      // Either participant (or self) contains their uid as a substring.
      allow read: if request.auth != null
        && (convoId.matches('.*' + request.auth.uid + '.*'));
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['participants'])
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && (convoId.matches('.*' + request.auth.uid + '.*'));
      allow delete: if false;
      match /messages/{msgId} {
        allow read: if request.auth != null
          && (convoId.matches('.*' + request.auth.uid + '.*'));
        // NodeBlast + DexNote both write `fromUid` (not `senderUid`).
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid
          && (convoId.matches('.*' + request.auth.uid + '.*'));
        allow update, delete: if false;
      }
    }
    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.type in ['suggestion', 'bug', 'poll'];
      allow update: if request.auth != null
        && (
          (resource.data.authorUid == request.auth.uid)
          ||
          (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['voters', 'score', 'options', 'pollVoters']))
        );
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }
    match /public_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && (
          request.resource.data.ownerUid == request.auth.uid
          ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['viewers', 'viewerCount'])
        );
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
    match /catalysts/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }
    match /votes/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.odcId == request.auth.uid
        && request.resource.data.keys().hasAll(['odcId', 'catalystId', 'type'])
        && request.resource.data.type in ['fire', 'frost'];
      allow update: if request.auth != null
        && resource.data.odcId == request.auth.uid
        && request.resource.data.type in ['fire', 'frost'];
      allow delete: if request.auth != null
        && resource.data.odcId == request.auth.uid;
    }
    match /nodesplit_questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid;
      allow delete: if false;
    }
    match /nodesplit_option_counts/{questionId} {
      allow read: if true;
      allow update: if request.auth != null
        && request.resource.data.questionId == resource.data.questionId;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['questionId', 'counts']);
      allow delete: if false;
    }
    match /nodesplit_votes/{voteId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }
    match /nodesplit_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text.size() <= 280;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }
    match /creator_votes/{voteId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.voterId;
      allow delete: if request.auth != null
        && resource.data.voterId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
