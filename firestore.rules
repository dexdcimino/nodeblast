// ══════════════════════════════════════════════════════════════════════════════
//  THIS FILE IS NOT THE CANONICAL FIRESTORE RULES FILE.
//
//  The real, deployed rules live in the DexNote repo:
//      <DexNote-repo>/firestore.rules
//
//  Both DexNote and NodeBlast deploy to the same Firestore database
//  (dexnote-d7047). The canonical file covers BOTH apps' collections.
//
//  DO NOT deploy this file. Doing so would overwrite the live rules with
//  a deny-all policy and break the entire app.
//
//  To deploy real rules: cd into the DexNote repo and run:
//      firebase deploy --only firestore:rules --project dexnote-d7047
// ══════════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
