# NodeBlast — Firebase configuration template
#
# 1. Copy this file to .env and fill in real values (from the Firebase
#    console — Project settings → General → Your apps → Web app).
# 2. Run `bash scripts/build-firebase-config.sh` to generate
#    js/firebase-config.local.js for local development.
# 3. For Vercel deploys, add every variable below to the Vercel project
#    dashboard (Project → Settings → Environment Variables). The same
#    build script runs automatically via the buildCommand in vercel.json.

# --- Production (deployed) ---
FIREBASE_API_KEY_PROD=
FIREBASE_AUTH_DOMAIN_PROD=
FIREBASE_DATABASE_URL_PROD=
FIREBASE_PROJECT_ID_PROD=
FIREBASE_STORAGE_BUCKET_PROD=
FIREBASE_MESSAGING_SENDER_ID_PROD=
FIREBASE_APP_ID_PROD=
FIREBASE_MEASUREMENT_ID_PROD=

# --- Development (localhost / 127.0.0.1) ---
FIREBASE_API_KEY_DEV=
FIREBASE_AUTH_DOMAIN_DEV=
FIREBASE_DATABASE_URL_DEV=
FIREBASE_PROJECT_ID_DEV=
FIREBASE_STORAGE_BUCKET_DEV=
FIREBASE_MESSAGING_SENDER_ID_DEV=
FIREBASE_APP_ID_DEV=
FIREBASE_MEASUREMENT_ID_DEV=
